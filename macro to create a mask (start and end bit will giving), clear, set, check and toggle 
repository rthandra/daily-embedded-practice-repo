/*
Write a macro to create a mask (start and end bit will giving), clear, set, check and toggle 
*/

/*

mask:
1. need the number of set bits of the mask between end and start
2. now make a width of the above
3. move it to the correct position
*/

#define MASK(start, end) (((1U << (end - start + 1)) - 1) << start)

int main() {

  int n = 3; //0011
  int start = 1;
  int end = 3;
  
  //clear
  n &= ~(MASK(start, end));

  //toggle
  n ^= MASK(start, end);

  //set
  n |= MASK(start, end);
  
  return 0;
}

}
