#define SIZE 4

typedef struct{

  int arr[SIZE];
  int head;
  int tail;
  int count;
}Buff;

int isFull(Buff *Circular){
  if(Circular->count == SIZE){
    return -1;
  }
  return 0;
}

int isEmpty(Buff *Circular){
  if(Circular->count == 0){
    return -1;
  }
  return 0;
}

int push(Buff *Circular, int val ){

  if(isFull(Circular)){
    return -1; //if the buffer is full, dont add more elements
  }
  Circular->arr[Circular->tail] = val;
  Circular->tail = (Circular->tail + 1) % SIZE;
  Circular->count++;
  return 0;
}

int pop(Buff *Circular, int *popped){
  
  if(isEmpty(Circular) == -1){
    return -1; 
  }
  *popped = Circular->arr[Circular->head];
  Circular->head = (Circular->head + 1) % SIZE;
  Circular->count--;

  return 0;
}

int main(){

  Buff Circular;
  Circular.count = 0;
  Circular.head = 0;
  Circular.tail = 0;

  push(&Circular, 1);
  push(&Circular, 2);
  push(&Circular, 3);
  push(&Circular, 4);

  int popped = 0;

  pop(&Circular, &popped);


  return 0;
}
